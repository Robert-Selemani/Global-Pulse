# Copy to .env for local development (values here are safe defaults).
# On Render these are configured in the dashboard / render.yaml instead.

# Port the server listens on (Render sets this automatically).
PORT=3000

# PostgreSQL connection string. When set, submissions are stored in Postgres.
# When unset (local dev), the app falls back to a JSON file (see DATA_DIR).
# DATABASE_URL=postgres://user:password@host:5432/global_pulse

# Directory for the JSON-file fallback when DATABASE_URL is not set.
# Leave unset locally to use the server/ directory.
# DATA_DIR=/var/data

# Password that unlocks the admin continent-focus control. CHANGE THIS.
ADMIN_PASSWORD=change-me

# Secret used to sign admin session cookies. Use a long random string.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string
