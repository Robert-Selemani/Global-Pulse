# Copy to .env for local development (values here are safe defaults).
# On Render these are configured in the dashboard / render.yaml instead.

# Port the server listens on (Render sets this automatically).
PORT=3000

# PostgreSQL connection string. When set, all data (accounts, polls,
# submissions, subscriptions) is stored in Postgres. When unset (local dev),
# the app uses an embedded SQLite database at DATA_DIR/data.db. The schema is
# created and migrated automatically on boot, and any legacy data.json is
# imported into SQLite on first run. (SQLite needs Node >= 22.5.)
# DATABASE_URL=postgres://user:password@host:5432/global_pulse

# Directory for the local SQLite database (and the legacy JSON fallback).
# Leave unset locally to use the server/ directory.
# DATA_DIR=/var/data

# Override the SQLite file location (defaults to DATA_DIR/data.db).
# SQLITE_PATH=/var/data/global-pulse.db

# Force the legacy JSON file store instead of SQLite (used by tests / the
# verify skill). Ignored when DATABASE_URL is set.
# GP_STORAGE=file

# In production (RENDER=1 or NODE_ENV=production) the server refuses to boot
# without DATABASE_URL, since on-disk storage is ephemeral there and would lose
# all data on every deploy. Set this to 1 to run ephemerally on purpose (demos).
# ALLOW_EPHEMERAL_STORAGE=1

# Accounts are stored in the database — the first person to sign up becomes
# the super admin. There is no ADMIN_PASSWORD any more. Participation codes are
# per poll and are generated from the organizer dashboard, not from env vars.

# Secret used to sign session cookies. Use a long random string.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string
