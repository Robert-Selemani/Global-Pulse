# Runtime data (regenerated on submissions)
server/data.json
server/data.json.tmp

# SQLite database (default local store) and its WAL sidecar files
server/data.db
server/data.db-wal
server/data.db-shm

# Persisted dev session secret (see resolveSessionSecret in server/index.js)
server/.session-secret

# Local environment secrets
.env
.env.local

# Machine-local Claude Code settings (project skills are tracked)
.claude/settings.local.json

# Dependencies (none required, but just in case)
node_modules/

# OS / editor cruft
.DS_Store
*.log
.vscode/
.idea/
